# MongoDB Connection
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/volunteerconnect

# JWT Secret (use a long random string in production)
JWT_SECRET=volunteerconnect_super_secret_key_2024_change_this

# Server Port
PORT=5000

# Email (Nodemailer - optional, use Gmail App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
